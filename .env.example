# BlaBlaCutter local environment.
# LLM API config is read directly from this file.
model_provider=OpenAI
model=gpt-5.5
base_url=https://api.openai.com/v1
wire_api=responses
OPENAI_API_KEY=

# Required only when input is a PDF that must be parsed through MinerU.
MINERU_API_TOKEN=

# Optional: use a different model for image analysis.
# MODEL_NAME_IMAGE=gpt-5.5
